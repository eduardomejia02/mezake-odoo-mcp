# ─── Odoo connection ──────────────────────────────────────────────────────────
ODOO_URL=https://yourcompany.odoo.com
ODOO_DB=your_database_name
ODOO_USER=your.email@example.com
ODOO_API_KEY=your_api_key_from_odoo_settings

# Optional: lock this deployment to a single company (Odoo company ID)
# ODOO_COMPANY_ID=1
# ODOO_COMPANY_NAME=My Company

# ─── Server ───────────────────────────────────────────────────────────────────
# PORT=8000
# RAILWAY_PUBLIC_DOMAIN=myapp.up.railway.app

# ─── Storage (Phase 3) ────────────────────────────────────────────────────────
# Railway injects DATABASE_URL when a Postgres plugin is attached.
# DATABASE_URL=postgresql://user:pass@host:5432/db

# ─── Auth (Phase 4) ───────────────────────────────────────────────────────────
# Fernet key for encrypting stored Odoo API keys at rest.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ENCRYPTION_KEY=
